{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibedraw/contracts/bridge-intent.schema.json",
  "title": "BridgeIntent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bridge_type",
    "material",
    "spans_m",
    "deck_width_m",
    "requested_drawings",
    "assumptions",
    "questions"
  ],
  "properties": {
    "bridge_type": {
      "type": "string",
      "enum": [
        "continuous_girder"
      ]
    },
    "material": {
      "type": "string",
      "enum": [
        "prestressed_concrete"
      ]
    },
    "spans_m": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number",
        "exclusiveMinimum": 0
      }
    },
    "deck_width_m": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "alignment_type": {
      "type": "string",
      "enum": [
        "straight",
        "curve"
      ]
    },
    "start_station": {
      "type": "string"
    },
    "superstructure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "section_type": {
          "type": "string",
          "enum": [
            "single_box_single_cell",
            "single_box_double_cell"
          ]
        },
        "girder_depth_policy": {
          "type": "string",
          "enum": [
            "auto",
            "manual"
          ]
        },
        "girder_depth_m": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "substructure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pier_type": {
          "type": "string",
          "enum": [
            "double_column",
            "solid_pier"
          ]
        },
        "abutment_type": {
          "type": "string",
          "enum": [
            "gravity",
            "seat"
          ]
        }
      }
    },
    "requested_drawings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "general_arrangement",
          "plan",
          "elevation",
          "typical_section"
        ]
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

