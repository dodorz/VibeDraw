{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibedraw/contracts/drawing-plan.schema.json",
  "title": "DrawingPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "drawing_id",
    "drawing_type",
    "sheet",
    "views"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "drawing_id": {
      "type": "string",
      "minLength": 1
    },
    "drawing_type": {
      "type": "string",
      "enum": [
        "general_arrangement"
      ]
    },
    "sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "size",
        "scale"
      ],
      "properties": {
        "size": {
          "type": "string",
          "enum": [
            "A1",
            "A2",
            "A3"
          ]
        },
        "scale": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "view_id",
          "type",
          "origin",
          "scale"
        ],
        "properties": {
          "view_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "plan",
              "elevation",
              "typical_section"
            ]
          },
          "origin": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "number"
            }
          },
          "scale": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    }
  }
}

